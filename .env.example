# ─────────────────────────────────────────────────────────────────────────────
# ELFANAA (الفناء) — frontend environment variables
#
# Every variable in this file can be overridden in EasyPanel's env-var UI
# without editing source. Set them there for production; keep this file as
# the canonical reference for what each variable does.
# Copy this file to `.env.local` and fill the values you need. Public vars
# (prefixed with NEXT_PUBLIC_) are inlined into the client bundle at build time.
# Backend service env lives in `backend/.env.example`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public site config ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://elfanaa.com
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_CURRENCY=SAR

# ── API mode ────────────────────────────────────────────────────────────────
# Leave blank to use the in-Next.js /api/orders fallback (single-tier deploy).
# Set to your FastAPI service URL for production (recommended): orders persist
# to Postgres, server-side pixel CAPIs fire, Google Sheets dashboard updates.
NEXT_PUBLIC_API_BASE_URL=

# ── Browser-side pixel IDs (public — client must boot the pixels) ───────────
# Their CAPI access tokens stay server-side in `backend/.env`.
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_SNAPCHAT_PIXEL_ID=

# ─── Production override (REQUIRED before deploy) ───────────────────────────
# The defaults below are LOCAL-DEV ONLY. Override every value below
# in EasyPanel's env-var UI before pointing a domain at this stack.
# Do NOT ship the literal string "elfanaa" as a production password.
POSTGRES_DB=elfanaa
POSTGRES_USER=elfanaa
POSTGRES_PASSWORD=elfanaa     # ← REPLACE with a strong password
DATABASE_URL=postgresql+asyncpg://elfanaa:elfanaa@elfanaa_database:5432/elfanaa
CORS_ORIGINS=http://localhost:3000,https://elfanaa.com

# ─────────────────────────────────────────────────────────────────────────────
# Below applies ONLY to the embedded Next.js fallback (`/api/orders` etc.)
# When using the FastAPI backend, configure these in `backend/.env` instead.
# ─────────────────────────────────────────────────────────────────────────────

# Outbound webhook signing — used by every dispatcher in lib/webhooks.
# Generate with: `openssl rand -hex 32`
WEBHOOK_SECRET=replace_me_with_a_long_random_string

# Generic CRM / ERP webhook — receives `{ event: "order.created", order }`
ORDERS_WEBHOOK_URL=

# Shipping partner integration (Aramex / SMSA / J&T / etc.)
SHIPPING_WEBHOOK_URL=

# ─── Google Sheets orders dashboard ─────────────────────────────────────────
# Every COD order from any product page appends one row to your sheet; if
# the customer accepts the post-purchase upsell the SAME row is updated
# in place (SKU / Product name / Total quantity / Variant price gain the
# upsell, separated by "/") so the final row is the final real order.
#
# Deploy steps (5 minutes — see webhook-script.js for the full guide):
#   1. New Google Sheet → Extensions → Apps Script → paste webhook-script.js
#   2. Replace API_KEY in the script with a long random string
#   3. Run setupHeaders() once from the editor
#   4. Deploy → New deployment → Web app (Execute: Me, Access: Anyone)
#   5. Copy the /exec URL into GOOGLE_SHEETS_WEBHOOK_URL below
#   6. Copy the SAME API_KEY value into GOOGLE_SHEETS_API_KEY below
#
# Leave both blank to skip the Sheets integration entirely — the order
# route still works, the dispatcher just no-ops.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# MaxMind GeoIP2 — IP fraud / geo-block (BACKEND service only)
# These are read by the FastAPI backend, NEVER by the Next.js frontend.
# Listed here as well so EasyPanel ops can find them in one place.
# ─────────────────────────────────────────────────────────────────────────────
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
ENABLE_IP_FRAUD_CHECK=false
ALLOWED_COUNTRIES=SA
WHITELISTED_PHONES=
