# ─────────────────────────────────────────────────────────────────────────────
# ELFANAA backend — environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env` for local dev; in EasyPanel set these per-service in the UI.
# Every variable here can be overridden in EasyPanel's env-var UI without
# editing source.

# ─── Production override (REQUIRED before deploy) ───────────────────────────
# The defaults below are LOCAL-DEV ONLY. Override every value below
# in EasyPanel's env-var UI before pointing a domain at this stack.
# Do NOT ship the literal string "elfanaa" as a production password.
POSTGRES_DB=elfanaa
POSTGRES_USER=elfanaa
POSTGRES_PASSWORD=elfanaa     # ← REPLACE with a strong password
DATABASE_URL=postgresql+asyncpg://elfanaa:elfanaa@elfanaa_database:5432/elfanaa
CORS_ORIGINS=http://localhost:3000,https://elfanaa.com

# ── Service ──────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Database (matches `docker-compose.yml`) ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://elfanaa:elfanaa@elfanaa_database:5432/elfanaa

# ── CORS — comma-separated. Include the storefront origin(s). ────────────────
CORS_ORIGINS=http://localhost:3000,https://elfanaa.com

# ── Outbound webhooks ────────────────────────────────────────────────────────
WEBHOOK_SECRET=replace_me_with_a_long_random_string
ORDERS_WEBHOOK_URL=
SHIPPING_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_API_KEY=

# ── Server-side pixel APIs (CAPI) ────────────────────────────────────────────
# All three are optional. Leave blank to disable that integration.
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_CAPI_TEST_EVENT_CODE=

TIKTOK_PIXEL_ID=
TIKTOK_EVENTS_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=

SNAPCHAT_PIXEL_ID=
SNAPCHAT_CAPI_ACCESS_TOKEN=
