{
  "name": "fanaa-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Internal multi-store AI ecommerce platform monorepo. See docs/architecture/PLATFORM.md for the canonical architecture document.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev --filter=fanaa",
    "build": "turbo run build",
    "build:fanaa": "turbo run build --filter=fanaa",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf .turbo node_modules **/node_modules **/.next **/.turbo",
    "db:generate": "pnpm --filter fanaa db:generate",
    "db:migrate": "pnpm --filter fanaa db:migrate",
    "db:migrate:dev": "pnpm --filter fanaa db:migrate:dev",
    "db:studio": "pnpm --filter fanaa db:studio"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}
