{
  "name": "@platform/ai-engine",
  "version": "0.0.0",
  "private": true,
  "description": "Provider-agnostic AI engine for the Fanaa Platform. M4 surface: provider contracts + env-driven registry + adapters (Anthropic, OpenAI, fal.ai, Firecrawl). Pipeline stages (M5) and Inngest functions (M6) land later. See docs/architecture/PLATFORM.md §11–§12.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./providers": "./src/providers/index.ts",
    "./providers/contracts": "./src/providers/contracts.ts",
    "./providers/schemas": "./src/providers/schemas.ts",
    "./providers/registry": "./src/providers/registry.ts",
    "./providers/healthcheck": "./src/providers/healthcheck.ts"
  },
  "files": ["src", "scripts"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "ping": "tsx scripts/check-providers.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@fal-ai/client": "^1.0.6",
    "@mendable/firecrawl-js": "^1.4.0",
    "@platform/catalog-schema": "workspace:*",
    "@platform/stores": "workspace:*",
    "openai": "^4.70.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
