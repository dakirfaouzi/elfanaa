# ─────────────────────────────────────────────────────────────────────────────
# Fanaa Studio — environment variables.
#
# Studio is the internal AI ecommerce production app. Auth is deliberately
# decoupled from Fanaa admin (different secret, different identity, different
# cookie name) so the two operator pools can be managed independently.
#
# For EasyPanel: set each STUDIO_* var in the studio service's environment
# (Runtime Environment Variables tab — NOT Build Arguments; nothing here is
# `NEXT_PUBLIC_*`). On startup the service serves /login but every login
# attempt fails with HTTP 503 until all three required vars are set.
# ─────────────────────────────────────────────────────────────────────────────

# Operator credentials.
# Email is the username; password lives in either STUDIO_PASSWORD_HASH
# (production, recommended) or STUDIO_PASSWORD (dev quick-start only).
STUDIO_EMAIL=studio@elfanaa.com

# bcrypt hash of the operator password ($2a or $2b prefix).
# Generate locally:
#   pnpm --filter fanaa run admin:hash-password
# Then paste the resulting `$2a$...` string here. The hash form is
# stronger than the plain form below — a leaked .env or shell history
# never reveals the operator password.
STUDIO_PASSWORD_HASH=

# OPTIONAL plain-text password. Used only when STUDIO_PASSWORD_HASH is empty.
# Never set both at once in production.
STUDIO_PASSWORD=

# JWT signing secret. Use ≥32 random bytes (e.g. `openssl rand -base64 48`).
# Rotating this secret instantly invalidates every existing Studio session.
# Distinct from the JWT_SECRET used by Fanaa admin; do NOT reuse.
STUDIO_JWT_SECRET=

# Optional — override the session cookie name. Defaults to `_fa_studio`.
# Change if Studio shares a domain with another _fa_* cookie consumer.
STUDIO_AUTH_COOKIE=
