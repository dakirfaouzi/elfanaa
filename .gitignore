# Per-workspace install trees (every apps/* and packages/* has its own
# node_modules under pnpm; the glob covers them all).
node_modules
**/node_modules
.next
**/.next
out
.env
.env.local
.env.*.local
.DS_Store
*.log
.vscode
.idea
# Turborepo cache (per-package and root).
.turbo
**/.turbo
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

# Python artifacts (used by scripts/remove-bg.py)
__pycache__/
*.pyc

# Operational data exports (not source code — kept out of git)
*.xlsx
*.csv

# Temp asset files used by one-off helper scripts
scripts/_*.png

# Prisma generated client (regenerated by `prisma generate` / postinstall)
node_modules/.prisma
# Admin env override (real secrets — never commit)
.env.admin
.env.admin.local
.env.admin.*.local
