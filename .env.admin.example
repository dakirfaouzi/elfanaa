# =====================================================================
# Fanaa Admin — environment variables
# =====================================================================
# Add these to your existing .env / .env.local / EasyPanel env tab.
# Nothing here replaces existing storefront vars (NEXT_PUBLIC_*, GOOGLE_SHEETS_*).
# All values shown are PLACEHOLDERS — replace before deploying.

# ---------- Database ----------
# Postgres connection string for the admin analytics tables.
# Recommended: point at the SAME database the FastAPI service already uses.
# The admin tables are created automatically by FastAPI's lifespan migration
# on startup — no manual `prisma migrate` or `psql -f` step needed.
#
# Default in docker-compose: reuses elfanaa_database. Override only if you
# want analytics tables in a separate Postgres instance.
ADMIN_DATABASE_URL=postgresql://elfanaa:elfanaa@elfanaa_database:5432/elfanaa

# ---------- Authentication ----------
# Email allowed to log into /admin/login.
ADMIN_EMAIL=ops@fanaa.com

# EITHER provide ADMIN_PASSWORD (plain — quick start) ...
ADMIN_PASSWORD=change-me-before-deploy

# ... OR provide ADMIN_PASSWORD_HASH (bcrypt — production).
# Generate one locally:   npm run admin:hash-password "your-strong-password"
# If both are set, the hash wins.
# ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Long random string used to sign the admin session cookie (JWT).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-48-bytes-of-random-base64url

# Optional: override the auth cookie name (default _fa_admin).
# ADMIN_AUTH_COOKIE=_fa_admin

# ---------- Traffic filter ----------
# Allowed ISO-2 country codes — sessions outside this list are flagged invalid.
# Default (when unset): SA,AE,KW,QA,BH,OM,YE
# ADMIN_ALLOWED_COUNTRIES=SA,AE,KW,QA,BH,OM

# Quality score threshold (0–100). Sessions below this are filtered out
# of analytics counts but still visible on the Traffic Quality page.
# ADMIN_QUALITY_THRESHOLD=60

# ---------- IP intelligence ----------
# MaxMind GeoIP2 Insights. Already required by the existing FastAPI service —
# add the same values on the Next.js service so /api/track can score traffic
# without a hop to the backend.
# (Optional: if unset, the dashboard works but skips VPN/proxy detection.)
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# ---------- Order ingestion ----------
# Point the EXISTING /api/orders webhook fan-out at the admin's signed sink.
# Zero code changes to /api/orders — it already forwards orders to this URL
# if set. Use the SAME WEBHOOK_SECRET your order route is already configured
# with so the HMAC signature validates.
ORDERS_WEBHOOK_URL=https://YOUR_DOMAIN/api/admin/ingest/orders
# WEBHOOK_SECRET already exists in your env — do NOT change it. Same value
# must be set on the service that runs /api/orders AND on the service that
# runs /api/admin/ingest/orders (typically the same Next.js container).
